{
  "version": 1,
  "name": "AFS Quest Compass",
  "target": {
    "processName": "RobloxPlayerBeta.exe",
    "titlePattern": "Roblox"
  },
  "safety": {
    "countdownSeconds": 3,
    "emergencyHotkey": "F8"
  },
  "nodes": [
    {
      "id": "start",
      "label": "Start",
      "position": { "x": 40, "y": 220 },
      "type": "start"
    },
    {
      "id": "check-chakra",
      "label": "Is Chakra complete?",
      "position": { "x": 220, "y": 220 },
      "type": "detectText",
      "region": { "x": 1515, "y": 540, "width": 390, "height": 55 },
      "text": "100%",
      "confidence": 45,
      "pollMs": 1000,
      "timeoutMs": 3000
    },
    {
      "id": "wait-for-chakra",
      "label": "Wait before checking Chakra again",
      "position": { "x": 220, "y": 400 },
      "type": "delay",
      "milliseconds": 10000
    },
    {
      "id": "chakra-loop",
      "label": "Bound Chakra checks",
      "position": { "x": 40, "y": 400 },
      "type": "loop",
      "maxIterations": 8640,
      "maxDurationMs": 86400000
    },
    {
      "id": "check-durability",
      "label": "Is Durability complete?",
      "position": { "x": 440, "y": 140 },
      "type": "detectText",
      "region": { "x": 1515, "y": 485, "width": 390, "height": 55 },
      "text": "100%",
      "confidence": 45,
      "pollMs": 1000,
      "timeoutMs": 3000
    },
    {
      "id": "check-strength",
      "label": "Is Strength complete?",
      "position": { "x": 440, "y": 300 },
      "type": "detectText",
      "region": { "x": 1515, "y": 595, "width": 390, "height": 55 },
      "text": "100%",
      "confidence": 45,
      "pollMs": 1000,
      "timeoutMs": 3000
    },
    {
      "id": "open-compass-durability",
      "label": "Open compass for Durability",
      "position": { "x": 670, "y": 140 },
      "type": "action",
      "kind": "click",
      "point": { "x": 59, "y": 739 },
      "durationMs": 0
    },
    {
      "id": "open-compass-strength",
      "label": "Open compass for Strength",
      "position": { "x": 670, "y": 300 },
      "type": "action",
      "kind": "click",
      "point": { "x": 59, "y": 739 },
      "durationMs": 0
    },
    {
      "id": "stop",
      "label": "Compass opened - choose destination",
      "position": { "x": 920, "y": 220 },
      "type": "stop"
    }
  ],
  "edges": [
    { "id": "start-check-chakra", "source": "start", "target": "check-chakra", "outcome": "next" },
    {
      "id": "chakra-complete",
      "source": "check-chakra",
      "target": "check-durability",
      "outcome": "found"
    },
    {
      "id": "chakra-incomplete",
      "source": "check-chakra",
      "target": "wait-for-chakra",
      "outcome": "notFound"
    },
    { "id": "wait-loop", "source": "wait-for-chakra", "target": "chakra-loop", "outcome": "next" },
    { "id": "loop-repeat", "source": "chakra-loop", "target": "check-chakra", "outcome": "repeat" },
    { "id": "loop-done", "source": "chakra-loop", "target": "stop", "outcome": "done" },
    {
      "id": "durability-incomplete",
      "source": "check-durability",
      "target": "open-compass-durability",
      "outcome": "notFound"
    },
    {
      "id": "durability-complete",
      "source": "check-durability",
      "target": "check-strength",
      "outcome": "found"
    },
    {
      "id": "strength-incomplete",
      "source": "check-strength",
      "target": "open-compass-strength",
      "outcome": "notFound"
    },
    { "id": "strength-complete", "source": "check-strength", "target": "stop", "outcome": "found" },
    {
      "id": "durability-compass-opened",
      "source": "open-compass-durability",
      "target": "stop",
      "outcome": "next"
    },
    {
      "id": "strength-compass-opened",
      "source": "open-compass-strength",
      "target": "stop",
      "outcome": "next"
    }
  ]
}
