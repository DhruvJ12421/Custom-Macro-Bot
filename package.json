{
  "name": "windows-macro-bot",
  "version": "0.1.0",
  "private": true,
  "main": "dist/main/main/index.js",
  "scripts": {
    "dev": "concurrently -k \"vite\" \"tsc -p tsconfig.main.json --watch\" \"wait-on tcp:5173 dist/main/main/index.js && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron .\"",
    "build": "npm run clean && tsc -p tsconfig.main.json && vite build",
    "start": "npm run build && electron .",
    "clean": "rimraf dist",
    "typecheck": "tsc -p tsconfig.main.json --noEmit && tsc -p tsconfig.renderer.json --noEmit",
    "test": "vitest run",
    "lint": "eslint . --max-warnings=0",
    "format:check": "prettier --check README.md package.json package-lock.json tsconfig.json tsconfig.main.json tsconfig.renderer.json vite.config.ts vitest.config.ts eslint.config.mjs \"src/**/*.{ts,tsx,css,html}\""
  },
  "prettier": {
    "singleQuote": true,
    "trailingComma": "all",
    "printWidth": 100
  },
  "dependencies": {
    "@nut-tree-fork/nut-js": "^4.2.6",
    "@xyflow/react": "^12.8.5",
    "electron-store": "^10.0.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "screenshot-desktop": "^1.15.2",
    "tesseract.js": "^6.0.1",
    "uiohook-napi": "^1.5.4",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@eslint/js": "^9.29.0",
    "@types/node": "^22.15.32",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@types/screenshot-desktop": "^1.15.0",
    "@vitejs/plugin-react": "^4.5.2",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "^43.0.0",
    "eslint": "^9.29.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.2.0",
    "prettier": "^3.5.3",
    "rimraf": "^6.0.1",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.34.1",
    "vite": "^6.1.0",
    "vitest": "^3.2.3",
    "wait-on": "^8.0.3"
  }
}
